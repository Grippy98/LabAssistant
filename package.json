{
  "name": "labassistant",
  "productName": "LabAssistant",
  "version": "2026.3.20",
  "description": "LabAssistant: Embedded test automation and control App",
  "main": "desktop/main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE=0 electron .",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on http://localhost:5173 && ELECTRON_RUN_AS_NODE=0 electron .\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "cd backend && python3 -m venv venv && ./venv/bin/pip install -r requirements.txt && ./venv/bin/pyinstaller --onefile --name LabAssistantBackend main.py",
    "package": "npm run build:frontend && electron-builder"
  },
  "build": {
    "appId": "com.grippy98.labassistant",
    "productName": "LabAssistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "frontend/dist/**/*",
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": [
          "LabAssistantBackend*"
        ]
      },
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64",
            "universal"
          ]
        }
      ]
    }
  },
  "keywords": [],
  "author": "Grippy98 <grippy98@example.com>",
  "homepage": "https://github.com/Grippy98/LabAssistant",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
